# === Required secrets — fill these in, never commit real values ===
# Shopify app credentials (Shopify Partners -> your app -> Client credentials).
# NOTE: Shopify now labels these "Client ID" / "Client secret"
# (formerly "API key" / "API secret key"). They are the same values.
SHOPIFY_API_KEY=        # paste Shopify "Client ID" here
SHOPIFY_API_SECRET=     # paste Shopify "Client secret" here

# Xero app credentials (Xero Developer -> My Apps -> your app)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# === Public, non-secret config (defaults shown) ===
# Public base URL for OAuth callbacks. Shopify installs need an HTTPS tunnel
# (e.g. cloudflared/ngrok); http://localhost:3000 is fine for Xero-only testing.
APP_URL=http://localhost:3000
PORT=3000

SHOPIFY_SCOPES=read_orders,read_shopify_payments_payouts
SHOPIFY_API_VERSION=2026-04

# Includes write scope so one-click fixes can post corrections (preview-only unless ALLOW_XERO_WRITES=true)
XERO_SCOPES=offline_access accounting.transactions accounting.settings.read
# Optional — defaults to ${APP_URL}/auth/xero/callback
XERO_REDIRECT_URI=

# === One-click fixes (optional; only needed to WRITE corrections to Xero) ===
# Safety switch — fixes only write to Xero when this is exactly "true".
ALLOW_XERO_WRITES=false
# Required to CREATE missing transactions (leave blank to preview only):
XERO_BANK_ACCOUNT_CODE=
XERO_SALES_ACCOUNT_CODE=
XERO_CONTACT_NAME=Shopify

NODE_ENV=development
