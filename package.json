{
  "name": "reconcilio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reconciliation & error-catching companion for Shopify <-> Xero accounting sync",
  "scripts": {
    "dev": "tsx src/index.ts",
    "serve": "tsx src/server.ts",
    "serve:watch": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "demo": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "shopify",
    "xero",
    "accounting",
    "reconciliation",
    "audit"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
